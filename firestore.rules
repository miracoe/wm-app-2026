rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    // ─── Users ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow create: if isOwner(uid) &&
        request.resource.data.totalPoints == 0 &&
        request.resource.data.currentRank == 99;
      allow update: if isAdmin() ||
        (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['totalPoints', 'currentRank', 'lastRank', 'badges',
                   'jokersLeft', 'insuranceLeft', 'stats'])) ||
        // Spionage: User darf Punkte & spionageLeft reduzieren + spiedMatches erweitern
        (isOwner(uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['totalPoints', 'spionageLeft', 'spiedMatches']) &&
          request.resource.data.totalPoints <= resource.data.totalPoints &&
          request.resource.data.spionageLeft <= resource.data.spionageLeft);
    }

    // ─── Matches ──────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();

      // Tips
      match /tips/{uid} {
        allow read: if isLoggedIn();
        allow create, update: if isOwner(uid) &&
          get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'upcoming';
        allow delete: if false;
      }

      // Reactions
      match /reactions/{reactionId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn() &&
          request.resource.data.uid == request.auth.uid;
        allow delete: if isLoggedIn() &&
          resource.data.uid == request.auth.uid;
        allow update: if false;
      }
    }

    // ─── Bonus Tips ───────────────────────────────────────────────────────
    // Jeder User darf sein eigenes Dokument lesen und schreiben
    // Deadline wird client-seitig erzwungen; Admin kann locked:true setzen
    match /bonusTips/{uid} {
      allow read: if isLoggedIn();
      allow create, update: if isOwner(uid) &&
        (resource == null || resource.data.get('locked', false) != true);
      allow delete: if false;
    }

    // ─── Admins ───────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isLoggedIn();
      allow write: if false;
    }

    // ─── Catch-all ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
