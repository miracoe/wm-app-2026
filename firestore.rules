rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    // ─── Users ────────────────────────────────────────────────────────────
    // Alle eingeloggten User dürfen alle Profile lesen (für Leaderboard)
    // Nur Admin darf Punkte, Rang, Badges schreiben
    // User selbst darf nur bei Ersterstellung schreiben (ensureUserDoc)
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow create: if isOwner(uid) &&
        request.resource.data.totalPoints == 0 &&
        request.resource.data.currentRank == 99;
      allow update: if isAdmin() ||
        // User darf nur eigene nicht-spielrelevante Felder ändern
        (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['totalPoints', 'currentRank', 'lastRank', 'badges',
                   'jokersLeft', 'insuranceLeft', 'stats']));
    }

    // ─── Admins ───────────────────────────────────────────────────────────
    // Separate Collection für Admin-UIDs (sicherer als env var im Client)
    match /admins/{uid} {
      allow read: if isLoggedIn();
      allow write: if false; // Nur über Firebase Console pflegen
    }

    // ─── Matches ──────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();

      // ─── Tips (Subcollection) ──────────────────────────────────────────
      match /tips/{uid} {
        allow read: if isLoggedIn();
        // User darf eigenen Tipp setzen, solange Spiel noch "upcoming" ist
        allow create, update: if isOwner(uid) &&
          get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'upcoming';
        allow delete: if false;
      }
    }

    // ─── Catch-all: alles andere verweigern ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
